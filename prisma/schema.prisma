generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  emailVerified          DateTime?
  image                  String?
  accounts               Account[]
  sessions               Session[]
  externalImportSessions ExternalImportSession[]

  role       Role      @default(ATHLETE)
  birthDate  DateTime?
  gender     String?

  athleteProfile AthleteProfile?
  coachProfile   CoachProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ATHLETE
  COACH
  ADMIN
}

model CoachProfile {
  id       String   @id @default(cuid())
  userId   String   @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubName String?
  athletes AthleteProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AthleteProfile {
  id                     String         @id @default(cuid())
  userId                 String         @unique
  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  abmnRegistrationNumber String?        @db.VarChar(6)

  coachId String?
  coach   CoachProfile? @relation(fields: [coachId], references: [id], onDelete: SetNull)

  results RaceResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RaceResult {
  id               String         @id @default(cuid())
  athleteProfileId String
  athlete          AthleteProfile @relation(fields: [athleteProfileId], references: [id], onDelete: Cascade)

  eventType            EventType              @default(POOL)
  competitionName      String
  date                 DateTime
  distance             Int
  stroke               Stroke?
  course               Course?
  category             String?
  openWaterEnvironment OpenWaterEnvironment?
  venueName            String?
  notes                String?

  timeMs     Int
  timeString String
  position   Int?
  isRelay    Boolean @default(false)
  recordTag  String? @db.VarChar(16)

  isPersonalBest Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExternalImportSession {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  source          ExternalImportSource
  phpSessionId    String
  token           String
  captchaCode     String
  captchaImageUrl String
  expiresAt       DateTime
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId, source])
  @@index([expiresAt])
}

enum Stroke {
  FREESTYLE
  BACKSTROKE
  BREASTSTROKE
  BUTTERFLY
  MEDLEY
}

enum Course {
  SHORT_COURSE
  LONG_COURSE
}

enum EventType {
  POOL
  OPEN_WATER
}

enum OpenWaterEnvironment {
  SEA
  RIVER
  LAKE
  LAGOON
  RESERVOIR
}

enum ExternalImportSource {
  ABMN_CURRICULO
}
